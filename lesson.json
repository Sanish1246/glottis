  "grammar": [
    {
  "title": "Nationality Adjectives - Agreement",
  "type": "table",
  "content": [
    {
      "point": "Masculine singular",
      "english": "Adjectives ending in -o",
      "example": "italiano, francese, tedesco, spagnolo",
      "audio": "Microsoft Cosimo - Italian (Italy)"
    },
    {
      "point": "Feminine singular",
      "english": "Adjectives ending in -a",
      "example": "italiana, francese, tedesca, spagnola",
      "audio": "Microsoft Cosimo - Italian (Italy)"
    },
    {
      "point": "Masculine plural",
      "english": "Adjectives ending in -i",
      "example": "italiani, francesi, tedeschi, spagnoli",
      "audio": "Microsoft Cosimo - Italian (Italy)"
    },
    {
      "point": "Feminine plural",
      "english": "Adjectives ending in -e",
      "example": "italiane, francesi, tedesche, spagnole",
      "audio": "Microsoft Cosimo - Italian (Italy)"
    }
  ],
  "notes": [
    "Nationality adjectives in Italian ALWAYS agree with the gender and number of the person/thing they describe.",
    "Most nationality adjectives follow the pattern: -o (masculine) / -a (feminine) / -i (plural masculine) / -e (plural feminine)",
    "Some adjectives end in -e for both masculine and feminine singular (e.g., francese, inglese) and become -i in the plural.",
    "Nationality adjectives are NOT capitalized in Italian (unlike in English).",
    "Examples: 'Io sono italiano' (I am Italian - male), 'Lei è italiana' (She is Italian - female)"
  ]
}
    
